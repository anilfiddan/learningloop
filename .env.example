# ===========================================
# Supabase Configuration
# ===========================================
# Get these from your Supabase project settings
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Wiro AI Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# Required
WIRO_BASE_URL=https://api.wiro.ai
WIRO_API_KEY=your_wiro_api_key_here
WIRO_API_SECRET=your_wiro_api_secret_here

# Model IDs (optional - defaults shown)
WIRO_LLM_MODEL_ID=google/gemma-2-2b-it
WIRO_IMAGE_MODEL_ID=google/nano-banana-pro
WIRO_VIDEO_MODEL_ID=veo
WIRO_TTS_MODEL_ID=google/gemini-2.5-tts
WIRO_STT_MODEL_ID=elevenlabs/speech-to-text

# Feature flags
ENABLE_STT=true

# Optional endpoint paths (defaults shown)
# WIRO_CHAT_PATH=/chat/completions
# WIRO_IMAGE_PATH=/images/generations
# WIRO_VIDEO_PATH=/video/generations
# WIRO_TTS_PATH=/audio/tts
# WIRO_STT_PATH=/audio/stt

# ===========================================
# Vercel Configuration (auto-set by Vercel)
# ===========================================
# VERCEL_URL=your-app.vercel.app
